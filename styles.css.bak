:root {
  color-scheme: dark;
  color: #111827;
  font-family: 'Inter', system-ui, sans-serif;
  font-synthesis: none;
  text-rendering: optimizeLegibility;
  line-height: 1.6;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  min-height: 100vh;
  background: radial-gradient(circle at top left, rgba(79, 147, 255, 0.18), transparent 18%), radial-gradient(circle at bottom right, rgba(13, 64, 187, 0.22), transparent 24%), #0b1728;
  color: #e2e8f0;
}

img {
  max-width: 100%;
  display: block;
}

a {
  color: inherit;
  text-decoration: none;
}

button,
input,
textarea {
  font: inherit;
}

body, input, textarea, button {
  font-family: 'Inter', system-ui, sans-serif;
}

.container {
  width: min(1180px, calc(100% - 2rem));
  margin: 0 auto;
}

.site-header {
  position: sticky;
  top: 0;
  z-index: 40;
  backdrop-filter: blur(12px);
  background: linear-gradient(180deg, rgba(2,6,23,0.92), rgba(8,18,33,0.86));
  border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  box-shadow: 0 8px 30px rgba(2, 6, 23, 0.45);
}

.header-inner,
.footer-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding: 1.6rem 0;
}

.brand {
  display: inline-flex;
  align-items: center;
}

.logo {
  height: 160px;
  width: auto;
}

.nav-links {
  display: flex;
  flex-wrap: wrap;
  gap: 1.8rem;
  font-size: 0.95rem;
}

.nav-links a {
  color: #cbd5e1;
  transition: color 0.18s ease, transform 0.18s ease;
  padding: 0.35rem 0.25rem;
  font-weight: 600;
}

.nav-links a:hover {
  color: #4f93ff;
  transform: translateY(-2px);
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999px;
  padding: 0.95rem 1.75rem;
  border: none;
  cursor: pointer;
  transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
}

.btn:hover {
  transform: translateY(-1px);
}

.btn-primary {
  background: linear-gradient(135deg, #4f93ff 0%, #0d55d8 100%);
  color: white;
  box-shadow: 0 18px 40px rgba(16, 78, 173, 0.22);
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.08);
  color: #4f93ff;
  border: 1px solid rgba(79, 147, 255, 0.25);
}

.btn-wsp {
  background: linear-gradient(135deg, #25D366 0%, #128C7E 100%);
  color: white;
  border: none;
  box-shadow: 0 12px 30px rgba(18, 140, 126, 0.18);
}

.contact-actions {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.hero-section {
  padding: 5.5rem 0 4rem;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0.96) 0%, rgba(15, 23, 42, 0.88) 100%);
}

.hero-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.2fr) minmax(360px, 1fr);
  gap: 3rem;
  align-items: center;
}

.eyebrow {
  margin: 0 0 1rem;
  font-size: 0.82rem;
  text-transform: uppercase;
  letter-spacing: 0.22em;
  color: #1d4ed8;
}

.hero-copy h1,
.section-header h2,
.benefit-copy h2,
.section-center h2,
.contact-copy h2 {
  margin: 0;
  font-size: clamp(2.8rem, 3vw, 4.4rem);
  line-height: 1.04;
  letter-spacing: -0.035em;
  color: #f8fafc;
}

.hero-text,
.benefit-copy p,
.contact-copy p {
  max-width: 40rem;
  margin: 1.25rem 0 2rem;
  color: #cbd5e1;
  font-size: 1.05rem;
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
}

.hero-stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1rem;
  margin-top: 2rem;
}

.hero-stats div {
  padding: 1rem 1.25rem;
  border-radius: 18px;
  background: rgba(79, 147, 255, 0.16);
  border: 1px solid rgba(79, 147, 255, 0.22);
}

.hero-stats strong {
  display: block;
  font-size: 1.6rem;
  color: #f8fafc;
}

.hero-stats span {
  display: block;
  margin-top: 0.25rem;
  color: #cbd5e1;
}

.hero-panel {
  position: relative;
  display: grid;
  gap: 1.75rem;
}

.hero-image-mask {
  overflow: hidden;
  border-radius: 32px;
  box-shadow: 0 36px 100px rgba(2, 6, 23, 0.6);
  border: 1px solid rgba(255,255,255,0.02);
}

.hero-image-mask img {
  width: 100%;
  height: auto;
  display: block;
  object-fit: cover;
}

.hero-card {
  padding: 1.75rem;
  border-radius: 26px;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(79, 147, 255, 0.08));
  border: 1px solid rgba(79, 147, 255, 0.24);
  box-shadow: 0 34px 90px rgba(0, 0, 0, 0.18);
}

.hero-card span {
  display: inline-block;
  margin-bottom: 0.75rem;
  font-size: 0.85rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #a5b4fc;
}

.hero-card strong {
  display: block;
  font-size: 1.35rem;
  margin-bottom: 0.85rem;
  color: #f8fafc;
}

.hero-card p {
  margin: 0;
  color: #cbd5e1;
}

.section {
  padding: 5rem 0;
}

.section-alt {
  background: linear-gradient(180deg, rgba(15, 23, 42, 0.95), rgba(15, 23, 42, 0.85));
}

.section-dark {
  background: #0f172a;
  color: white;
}

.section-header,
.contact-copy {
  max-width: 42rem;
}

.feature-grid,
.benefits-grid,
.project-grid,
.contact-grid {
  display: grid;
  gap: 1.75rem;
}

.feature-grid {
  margin-top: 2.5rem;
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.feature-card {
  padding: 2rem;
  border-radius: 20px;
  background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(79,147,255,0.02));
  border: 1px solid rgba(255,255,255,0.04);
  box-shadow: 0 18px 50px rgba(3, 7, 18, 0.45);
  transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
}

.feature-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 36px 100px rgba(15, 23, 42, 0.14);
  border-color: rgba(29, 78, 216, 0.2);
}

.feature-icon {
  width: 56px;
  height: 56px;
  display: grid;
  place-items: center;
  margin-bottom: 1.25rem;
  border-radius: 12px;
  background: rgba(15,23,42,0.62);
  color: #ffffff;
  font-size: 1.25rem;
  border: 1px solid rgba(255,255,255,0.03);
}

.feature-card h3 {
  margin-top: 0;
  margin-bottom: 0.85rem;
  font-size: 1.3rem;
}

.feature-card p {
  margin: 0;
  color: #cbd5e1;
}

.benefits-grid {
  grid-template-columns: 1.1fr 0.9fr;
  align-items: center;
}

.benefit-list {
  margin: 1.8rem 0 0;
  padding-left: 1.25rem;
  list-style: disc;
  color: #cbd5e1;
}

.benefit-list li {
  margin-bottom: 0.9rem;
}

.benefit-image .benefit-panel {
  border-radius: 32px;
  overflow: hidden;
  box-shadow: 0 36px 100px rgba(15, 23, 42, 0.14);
}

.benefit-image img {
  width: 100%;
  display: block;
}

.section-center {
  text-align: center;
}

.project-grid {
  margin-top: 2.5rem;
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.project-card {
  padding: 1.75rem;
  border-radius: 18px;
  background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(15,23,42,0.12));
  border: 1px solid rgba(255,255,255,0.04);
  box-shadow: 0 14px 40px rgba(2,6,23,0.45);
}

.project-card h3 {
  margin-top: 0;
  margin-bottom: 0.8rem;
  font-size: 1.2rem;
}

.project-card p {
  margin: 0;
  color: rgba(255, 255, 255, 0.82);
  line-height: 1.7;
}

.contact-grid {
  grid-template-columns: 1fr 1fr;
  align-items: start;
}

.contact-copy h2 {
  font-size: clamp(2.6rem, 3vw, 4rem);
}

.contact-form {
  display: grid;
  gap: 1rem;
}

.contact-form label {
  display: grid;
  gap: 0.5rem;
  font-size: 0.95rem;
  color: #ffffff;
}

.contact-form input,
.contact-form textarea {
  width: 100%;
  border-radius: 16px;
  border: 1px solid rgba(255, 255, 255, 0.14);
  padding: 1rem 1.1rem;
  background: rgba(255, 255, 255, 0.08);
  color: white;
}

.contact-form input::placeholder,
.contact-form textarea::placeholder {
  color: rgba(255, 255, 255, 0.68);
}

.site-footer {
  padding: 2rem 0;
  background: linear-gradient(135deg, #0c1728 0%, #0d2a5e 100%);
}

.footer-inner {
  gap: 1rem;
}

.footer-links {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

.footer-links a {
  color: #cbd5e1;
}

@media (max-width: 1024px) {
  .hero-grid,
  .benefits-grid,
  .project-grid,
  .contact-grid {
    grid-template-columns: 1fr;
  }

  .feature-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 720px) {
  .header-inner,
  .footer-inner {
    flex-direction: column;
    align-items: stretch;
    text-align: center;
  }

  .nav-links {
    justify-content: center;
  }

  .hero-copy h1,
  .section-header h2,
  .benefit-copy h2,
  .contact-copy h2 {
    font-size: 2.3rem;
  }

  .hero-stats {
    grid-template-columns: 1fr;
  }

  .contact-form input,
  .contact-form textarea {
    background: rgba(255, 255, 255, 0.1);
  }
  .logo {
    height: 80px;
  }
}
